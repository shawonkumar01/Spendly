@model IEnumerable<Spendly.Models.Expense>
@{
    ViewData["Title"] = "User Expenses";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">@ViewBag.UserName</h4>
        <p class="text-muted small mb-0">@ViewBag.UserEmail</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Date</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Title</td>
                        <td>
                            <span class="badge"
                                  style="background-color:@e.Category.ColorHex">
                                @e.Category.Name
                            </span>
                        </td>
                        <td>@e.Date.ToString("dd MMM yyyy")</td>
                        <td class="text-end fw-bold">
                            ৳@e.Amount.ToString("N2")
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="3" class="fw-bold">Total</td>
                    <td class="text-end fw-bold text-primary">
                        ৳@Model.Sum(e => e.Amount).ToString("N2")
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>