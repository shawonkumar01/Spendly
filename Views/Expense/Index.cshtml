@model IEnumerable<Spendly.Models.Expense>
@{
    ViewData["Title"] = "My Expenses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">My Expenses</h4>
    <a asp-action="Create" class="btn btn-primary">+ Add Expense</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Category</label>
                <select name="categoryId" class="form-select form-select-sm">
                    <option value="">All Categories</option>
                    @foreach (var c in ViewBag.Categories)
                    {
                        <option value="@c.Value"
                                selected="@(ViewBag.SelectedCategory?.ToString() == c.Value)">
                            @c.Text
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">From</label>
                <input type="date" name="from" value="@ViewBag.From"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">To</label>
                <input type="date" name="to" value="@ViewBag.To"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Keyword</label>
                <input type="text" name="keyword" value="@ViewBag.Keyword"
                       class="form-control form-control-sm"
                       placeholder="Search title or notes..." />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Date</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Title</td>
                        <td>
                            <span class="badge"
                                  style="background-color:@e.Category.ColorHex">
                                @e.Category.Name
                            </span>
                        </td>
                        <td>@e.Date.ToString("dd MMM yyyy")</td>
                        <td class="text-end fw-bold">৳@e.Amount.ToString("N2")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@e.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@e.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this expense?')">
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No expenses found. <a asp-action="Create">Add one!</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="3" class="fw-bold">Total</td>
                    <td class="text-end fw-bold text-primary">
                        ৳@ViewBag.Total.ToString("N2")
                    </td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>